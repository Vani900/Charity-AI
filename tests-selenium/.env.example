# CharityAI Selenium Test Suite — Environment Variables
# Copy this file to .env and fill in your values

# App URL (default: http://localhost:5173)
BASE_URL=http://localhost:5173

# Run headless (true for CI, false for visual debugging)
HEADLESS=false

# Browser dimensions
BROWSER_WIDTH=1440
BROWSER_HEIGHT=900

# ChromeDriver executable path
